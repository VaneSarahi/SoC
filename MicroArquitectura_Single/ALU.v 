module ALU (
    input [31:0] a,
    input [31:0] b,
    input [2:0] aluCtrl,
    output reg flag,
    output reg [31:0] result 
);

always @(*)
begin  
    case (aluCtrl)
        3'b000 : result = a+b;
        3'b001 : result = a-b;
        3'b010 : result = a&b;
        3'b011 : result = a|b;
        3'b101 : result = a<<b;
        default: result= 32'b0;
    endcase 

    if (result==0)
        flag=1;
    else 
        flag=0;
end 



endmodule 